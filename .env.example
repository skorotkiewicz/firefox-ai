# Model Configuration
MODEL_PATH=/path/to/your/gemma-4-E2B-it.litertlm

# Or download from HuggingFace (if MODEL_PATH not set)
# HF_REPO=litert-community/gemma-4-E2B-it-litert-lm
# HF_FILENAME=gemma-4-E2B-it.litertlm

# Backend Configuration
BACKEND=GPU
VISION_BACKEND=GPU
AUDIO_BACKEND=CPU

# Server Configuration
HOST=0.0.0.0
PORT=8000

# System Prompt
# LLM_SYSTEM_PROMPT="- You are LLM named Bubby.\n- Do not attempt to guess or elaborate.\n- Be concise."

# Optional: SSL Configuration
# To generate self-signed certificates for local, run:
#   openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 365 -nodes -subj "/CN=192.168.0.124"
# Then uncomment and set paths below:
# SSL_KEYFILE=/path/to/key.pem
# SSL_CERTFILE=/path/to/cert.pem
